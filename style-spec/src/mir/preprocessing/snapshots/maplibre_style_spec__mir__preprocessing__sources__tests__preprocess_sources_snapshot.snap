      - Array:
          meta:
            spec_name: bounds
            rust_name: bounds
            optional: true
            transition: false
            expression: ~
            doc: "An array containing the longitude and latitude of the southwest and northeast corners of the source's bounding box in the following order: `[sw.lng, sw.lat, ne.lng, ne.lat]`. When this property is included in a source, no tiles outside of the given bounds are requested by MapLibre."
            example: ~
            units: ~
          default:
            - -180
            - -85.051129
            - 180
            - 85.051129
          element:
            Number:
              min: ~
              max: ~
          length: 4
      - Number:
          meta:
            spec_name: maxzoom
            rust_name: maxzoom
            optional: true
            transition: false
            expression: ~
            doc: "Maximum zoom level for which tiles are available, as in the TileJSON spec. Data from tiles at the maxzoom are used when displaying the map at higher zoom levels."
            example: ~
            units: ~
          default: 22
          min: ~
          max: ~
          period: ~
      - Number:
          meta:
            spec_name: minzoom
            rust_name: minzoom
            optional: true
            transition: false
            expression: ~
            doc: "Minimum zoom level for which tiles are available, as in the TileJSON spec."
            example: ~
            units: ~
          default: 0
          min: ~
          max: ~
          period: ~
      - Enum:
          meta:
            spec_name: scheme
            rust_name: scheme
            optional: true
            transition: false
            expression: ~
            doc: Influences the y direction of the tile coordinates. The global-mercator (aka Spherical Mercator) profile is assumed.
            example: ~
            units: ~
          default: xyz
          variants:
            Regular:
              variants:
                tms:
                  doc: OSGeo spec scheme.
                xyz:
                  doc: Slippy map tilenames scheme.
      - Number:
          meta:
            spec_name: tileSize
            rust_name: tile_size
            optional: true
            transition: false
            expression: ~
            doc: The minimum visual size to display tiles for this layer. Only configurable for raster layers.
            example: ~
            units: pixels
          default: 512
          min: ~
          max: ~
          period: ~
      - Array:
          meta:
            spec_name: tiles
            rust_name: tiles
            optional: true
            transition: false
            expression: ~
            doc: "An array of one or more tile source URLs, as in the TileJSON spec."
            example: ~
            units: ~
          default: ~
          element: String
          length: ~
      - String:
          meta:
            spec_name: url
            rust_name: url
            optional: true
            transition: false
            expression: ~
            doc: "A URL to a TileJSON resource. Supported protocols are `http:` and `https:`."
            example: ~
            units: ~
          default: ~
