      "id": "unary-any-filter",
      "type": "fill",
      "source": "example",
      "source-layer": "water",
      "filter": ["any", ["==", ["get", "kind"], "pond"]]
    },
    {
      "id": "unary-all-filter",
      "type": "line",
      "source": "example",
      "source-layer": "road",
      "filter": ["all", ["has", "structure"]]
    },
    {
      "id": "double-not-filter",
      "type": "circle",
      "source": "example",
      "source-layer": "poi",
      "filter": ["!", ["!", ["has", "name"]]],
      "paint": {
        "circle-radius": ["any", ["literal", 4]]
      }
    },
    {
      "id": "nested-any",
      "type": "fill",
      "source": "example",
      "source-layer": "land",
      "filter": ["any", ["any", ["==", ["get", "area"], 1]]]
    },
    {
      "id": "bare-any-filter",
      "type": "line",
      "source": "example",
      "source-layer": "road",
      "filter": ["any"]
    }
  ]
