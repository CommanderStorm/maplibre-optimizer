{
  "source_types": {
    "geojson": {
      "fields": [
        {
          "String": {
            "meta": {
              "spec_name": "attribution",
              "rust_name": "attribution",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "Contains an attribution to be displayed when the map is shown to a user.",
              "example": null,
              "units": null
            },
            "default": null
          }
        },
        {
          "Number": {
            "meta": {
              "spec_name": "buffer",
              "rust_name": "buffer",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "Size of the tile buffer on each side. A value of 0 produces no buffer. A value of 512 produces a buffer as wide as the tile itself. Larger values produce fewer rendering artifacts near tile edges and slower performance.\n\nRange: 0..=512",
              "example": null,
              "units": null
            },
            "default": 128,
            "min": 0.0,
            "max": 512.0,
            "period": null
          }
        },
        {
          "Boolean": {
            "meta": {
              "spec_name": "cluster",
              "rust_name": "cluster",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "If the data is a collection of point features, setting this to true clusters the points by radius into groups. Cluster groups become new `Point` features in the source with additional properties:\n\n * `cluster` Is `true` if the point is a cluster \n\n * `cluster_id` A unique id for the cluster to be used in conjunction with the [cluster inspection methods](https://maplibre.org/maplibre-gl-js/docs/API/classes/GeoJSONSource/#getclusterexpansionzoom)\n\n * `point_count` Number of original points grouped into this cluster\n\n * `point_count_abbreviated` An abbreviated point count",
              "example": null,
              "units": null
            },
            "default": false
          }
        },
        {
          "Number": {
            "meta": {
              "spec_name": "clusterMaxZoom",
              "rust_name": "cluster_max_zoom",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "Max zoom on which to cluster points if clustering is enabled. Defaults to one zoom less than maxzoom (so that last zoom features are not clustered). Clusters are re-evaluated at integer zoom levels so setting clusterMaxZoom to 14 means the clusters will be displayed until z15.",
              "example": null,
              "units": null
            },
            "default": null,
            "min": null,
            "max": null,
            "period": null
          }
        },
        {
          "Number": {
            "meta": {
              "spec_name": "clusterMinPoints",
              "rust_name": "cluster_min_points",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "Minimum number of points necessary to form a cluster if clustering is enabled. Defaults to `2`.",
              "example": null,
              "units": null
            },
            "default": null,
            "min": null,
            "max": null,
            "period": null
          }
        },
        {
          "Star": {
            "spec_name": "clusterProperties",
            "rust_name": "cluster_properties",
            "optional": true,
            "transition": false,
            "expression": null,
            "doc": "An object defining custom properties on the generated clusters if clustering is enabled, aggregating values from clustered points. Has the form `{\"property_name\": [operator, map_expression]}`. `operator` is any expression function that accepts at least 2 operands (e.g. `\"+\"` or `\"max\"`) — it accumulates the property value from clusters/points the cluster contains; `map_expression` produces the value of a single point.\n\nExample: `{\"sum\": [\"+\", [\"get\", \"scalerank\"]]}`.\n\nFor more advanced use cases, in place of `operator`, you can use a custom reduce expression that references a special `[\"accumulated\"]` value, e.g.:\n\n`{\"sum\": [[\"+\", [\"accumulated\"], [\"get\", \"sum\"]], [\"get\", \"scalerank\"]]}`",
            "example": null,
            "units": null
          }
        },
        {
          "Number": {
            "meta": {
              "spec_name": "clusterRadius",
              "rust_name": "cluster_radius",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "Radius of each cluster if clustering is enabled. A value of 512 indicates a radius equal to the width of a tile.\n\nRange: 0..",
              "example": null,
              "units": null
            },
            "default": 50,
            "min": 0.0,
            "max": null,
            "period": null
          }
        },
        {
          "Star": {
            "spec_name": "data",
            "rust_name": "data",
            "optional": false,
            "transition": false,
            "expression": null,
            "doc": "A URL to a GeoJSON file, or inline GeoJSON.",
            "example": null,
            "units": null
          }
        },
        {
          "Reference": {
            "meta": {
              "spec_name": "filter",
              "rust_name": "filter",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "An expression for filtering features prior to processing them for rendering.",
              "example": null,
              "units": null
            },
            "target": "filter"
          }
        },
        {
          "Boolean": {
            "meta": {
              "spec_name": "generateId",
              "rust_name": "generate_id",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "Whether to generate ids for the geojson features. When enabled, the `feature.id` property will be auto assigned based on its index in the `features` array, over-writing any previous values.",
              "example": null,
              "units": null
            },
            "default": false
          }
        },
        {
          "Boolean": {
            "meta": {
              "spec_name": "lineMetrics",
              "rust_name": "line_metrics",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "Whether to calculate line distance metrics. This is required for line layers that specify `line-gradient` values.",
              "example": null,
              "units": null
            },
            "default": false
          }
        },
        {
          "Number": {
            "meta": {
              "spec_name": "maxzoom",
              "rust_name": "maxzoom",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "Maximum zoom level at which to create vector tiles (higher means greater detail at high zoom levels).",
              "example": null,
              "units": null
            },
            "default": 18,
            "min": null,
            "max": null,
            "period": null
          }
        },
        {
          "PromoteId": {
            "spec_name": "promoteId",
            "rust_name": "promote_id",
            "optional": true,
            "transition": false,
            "expression": null,
            "doc": "A property to use as a feature id (for feature state). Either a property name, or an object of the form `{<sourceLayer>: <propertyName>}`.",
            "example": null,
            "units": null
          }
        },
        {
          "Number": {
            "meta": {
              "spec_name": "tolerance",
              "rust_name": "tolerance",
              "optional": true,
              "transition": false,
              "expression": null,
              "doc": "Douglas-Peucker simplification tolerance (higher means simpler geometries and faster performance).",
              "example": null,
              "units": null
            },
            "default": 0.375,
            "min": null,
            "max": null,
            "period": null
          }
        }
      ],
      "discriminant_value": "geojson"
    },
