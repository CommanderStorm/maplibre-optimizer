{"run_id":"1773950048-162577813","line":49,"new":{"module_name":"maplibre_style_spec__mir__preprocessing__layers","snapshot_name":"decode_top_level","metadata":{"source":"maplibre-style-spec/src/mir/preprocessing/layers.rs","assertion_line":49,"expression":"layers"},"snapshot":"{\n  \"common_fields\": {\n    \"filter\": {\n      \"type\": \"String\",\n      \"default\": null,\n      \"doc\": \"A expression specifying conditions on source features. Only features that match the filter are displayed. Zoom expressions in filters are only evaluated at integer zoom levels. The `feature-state` expression is not supported in filter expressions.\",\n      \"required\": false,\n      \"expression\": null\n    },\n    \"id\": {\n      \"type\": \"String\",\n      \"default\": null,\n      \"doc\": \"Unique layer name.\",\n      \"required\": true,\n      \"expression\": null\n    },\n    \"maxzoom\": {\n      \"type\": {\n        \"Number\": {\n          \"min\": 0.0,\n          \"max\": 24.0\n        }\n      },\n      \"default\": null,\n      \"doc\": \"The maximum zoom level for the layer. At zoom levels equal to or greater than the maxzoom, the layer will be hidden.\",\n      \"required\": false,\n      \"expression\": null\n    },\n    \"metadata\": {\n      \"type\": \"State\",\n      \"default\": null,\n      \"doc\": \"Arbitrary properties useful to track with the layer, but do not influence rendering. Properties should be prefixed to avoid collisions, like 'maplibre:'.\",\n      \"required\": false,\n      \"expression\": null\n    },\n    \"minzoom\": {\n      \"type\": {\n        \"Number\": {\n          \"min\": 0.0,\n          \"max\": 24.0\n        }\n      },\n      \"default\": null,\n      \"doc\": \"The minimum zoom level for the layer. At zoom levels less than the minzoom, the layer will be hidden.\",\n      \"required\": false,\n      \"expression\": null\n    },\n    \"source\": {\n      \"type\": \"String\",\n      \"default\": null,\n      \"doc\": \"Name of a source description to be used for this layer. Required for all layer types except `background`.\",\n      \"required\": false,\n      \"expression\": null\n    },\n    \"source-layer\": {\n      \"type\": \"String\",\n      \"default\": null,\n      \"doc\": \"Layer to use from a vector tile source. Required for vector tile sources; prohibited for all other source types, including GeoJSON sources.\",\n      \"required\": false,\n      \"expression\": null\n    }\n  },\n  \"layer_types\": {\n    \"background\": {\n      \"layout\": {\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"background-color\": {\n          \"type\": \"Color\",\n          \"default\": \"#000000\",\n          \"doc\": \"The color with which the background will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"background-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity at which the background will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"background-pattern\": {\n          \"type\": {\n            \"ResolvedImage\": {\n              \"tokens\": false\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Name of image in sprite to use for drawing an image background. For seamless patterns, image width and height must be a factor of two (2, 4, 8, ..., 512). Note that zoom-dependent expressions will be evaluated only at integer zoom levels.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      }\n    },\n    \"circle\": {\n      \"layout\": {\n        \"circle-sort-key\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Sorts features in ascending order based on this value. Features with a higher sort key will appear above features with a lower sort key.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"circle-blur\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Amount to blur the circle. 1 blurs the circle such that only the centerpoint is full opacity.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"circle-color\": {\n          \"type\": \"Color\",\n          \"default\": \"#000000\",\n          \"doc\": \"The fill color of the circle.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"circle-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity at which the circle will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"circle-pitch-alignment\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"viewport\",\n          \"doc\": \"Orientation of circle when map is pitched.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"circle-pitch-scale\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"map\",\n          \"doc\": \"Controls the scaling behavior of the circle when the map is pitched.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"circle-radius\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 5,\n          \"doc\": \"Circle radius.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"circle-stroke-color\": {\n          \"type\": \"Color\",\n          \"default\": \"#000000\",\n          \"doc\": \"The stroke color of the circle.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"circle-stroke-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity of the circle's stroke.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"circle-stroke-width\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"The width of the circle's stroke. Strokes are placed outside of the `circle-radius`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"circle-translate\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": 2\n            }\n          },\n          \"default\": [\n            0,\n            0\n          ],\n          \"doc\": \"The geometry's offset. Values are [x, y] where negatives indicate left and up, respectively.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"circle-translate-anchor\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"map\",\n          \"doc\": \"Controls the frame of reference for `circle-translate`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      }\n    },\n    \"color-relief\": {\n      \"layout\": {\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"color-relief-color\": {\n          \"type\": \"Color\",\n          \"default\": null,\n          \"doc\": \"Defines the color of each pixel based on its elevation. Should be an expression that uses `[\\\"elevation\\\"]` as input.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"color-relief-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity at which the color-relief will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      }\n    },\n    \"fill\": {\n      \"layout\": {\n        \"fill-sort-key\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Sorts features in ascending order based on this value. Features with a higher sort key will appear above features with a lower sort key.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"fill-antialias\": {\n          \"type\": \"Boolean\",\n          \"default\": true,\n          \"doc\": \"Whether or not the fill should be antialiased.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"fill-color\": {\n          \"type\": \"Color\",\n          \"default\": \"#000000\",\n          \"doc\": \"The color of the filled part of this layer. This color can be specified as `rgba` with an alpha component and the color's opacity will not affect the opacity of the 1px stroke, if it is used.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"fill-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity of the entire fill layer. In contrast to the `fill-color`, this value will also affect the 1px stroke around the fill, if the stroke is used.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"fill-outline-color\": {\n          \"type\": \"Color\",\n          \"default\": null,\n          \"doc\": \"The outline color of the fill. Matches the value of `fill-color` if unspecified.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"fill-pattern\": {\n          \"type\": {\n            \"ResolvedImage\": {\n              \"tokens\": false\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Name of image in sprite to use for drawing image fills. For seamless patterns, image width and height must be a factor of two (2, 4, 8, ..., 512). Note that zoom-dependent expressions will be evaluated only at integer zoom levels.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"fill-translate\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": 2\n            }\n          },\n          \"default\": [\n            0,\n            0\n          ],\n          \"doc\": \"The geometry's offset. Values are [x, y] where negatives indicate left and up, respectively.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"fill-translate-anchor\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"map\",\n          \"doc\": \"Controls the frame of reference for `fill-translate`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      }\n    },\n    \"fill-extrusion\": {\n      \"layout\": {\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"fill-extrusion-base\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"The height with which to extrude the base of this layer. Must be less than or equal to `fill-extrusion-height`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"fill-extrusion-color\": {\n          \"type\": \"Color\",\n          \"default\": \"#000000\",\n          \"doc\": \"The base color of the extruded fill. The extrusion's surfaces will be shaded differently based on this color in combination with the root `light` settings. If this color is specified as `rgba` with an alpha component, the alpha component will be ignored; use `fill-extrusion-opacity` to set layer opacity.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"fill-extrusion-height\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"The height with which to extrude this layer.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"fill-extrusion-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity of the entire fill extrusion layer. This is rendered on a per-layer, not per-feature, basis, and data-driven styling is not available.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"fill-extrusion-pattern\": {\n          \"type\": {\n            \"ResolvedImage\": {\n              \"tokens\": false\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Name of image in sprite to use for drawing images on extruded fills. For seamless patterns, image width and height must be a factor of two (2, 4, 8, ..., 512). Note that zoom-dependent expressions will be evaluated only at integer zoom levels.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"fill-extrusion-translate\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": 2\n            }\n          },\n          \"default\": [\n            0,\n            0\n          ],\n          \"doc\": \"The geometry's offset. Values are [x, y] where negatives indicate left and up (on the flat plane), respectively.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"fill-extrusion-translate-anchor\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"map\",\n          \"doc\": \"Controls the frame of reference for `fill-extrusion-translate`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"fill-extrusion-vertical-gradient\": {\n          \"type\": \"Boolean\",\n          \"default\": true,\n          \"doc\": \"Whether to apply a vertical gradient to the sides of a fill-extrusion layer. If true, sides will be shaded slightly darker farther down.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      }\n    },\n    \"heatmap\": {\n      \"layout\": {\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"heatmap-color\": {\n          \"type\": \"Color\",\n          \"default\": [\n            \"interpolate\",\n            [\n              \"linear\"\n            ],\n            [\n              \"heatmap-density\"\n            ],\n            0,\n            \"rgba(0, 0, 255, 0)\",\n            0.1,\n            \"royalblue\",\n            0.3,\n            \"cyan\",\n            0.5,\n            \"lime\",\n            0.7,\n            \"yellow\",\n            1,\n            \"red\"\n          ],\n          \"doc\": \"Defines the color of each pixel based on its density value in a heatmap.  Should be an expression that uses `[\\\"heatmap-density\\\"]` as input.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"heatmap-intensity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"Similar to `heatmap-weight` but controls the intensity of the heatmap globally. Primarily used for adjusting the heatmap based on zoom level.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"heatmap-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The global opacity at which the heatmap layer will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"heatmap-radius\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 1.0,\n              \"max\": null\n            }\n          },\n          \"default\": 30,\n          \"doc\": \"Radius of influence of one heatmap point in pixels. Increasing the value makes the heatmap smoother, but less detailed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"heatmap-weight\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"A measure of how much an individual point contributes to the heatmap. A value of 10 would be equivalent to having 10 points of weight 1 in the same spot. Especially useful when combined with clustering.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        }\n      }\n    },\n    \"hillshade\": {\n      \"layout\": {\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"hillshade-accent-color\": {\n          \"type\": \"Color\",\n          \"default\": \"#000000\",\n          \"doc\": \"The shading color used to accentuate rugged terrain like sharp cliffs and gorges.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"hillshade-exaggeration\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 0.5,\n          \"doc\": \"Intensity of the hillshade\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"hillshade-highlight-color\": {\n          \"type\": \"ColorArray\",\n          \"default\": \"#FFFFFF\",\n          \"doc\": \"The shading color of areas that faces towards the light source(s). Only when `hillshade-method` is set to `multidirectional` can you specify multiple light sources.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"hillshade-illumination-altitude\": {\n          \"type\": {\n            \"NumberArray\": {\n              \"min\": 0.0,\n              \"max\": 90.0\n            }\n          },\n          \"default\": 45,\n          \"doc\": \"The altitude of the light source(s) used to generate the hillshading with 0 as sunset and 90 as noon. Only when `hillshade-method` is set to `multidirectional` can you specify multiple light sources.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"hillshade-illumination-anchor\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"viewport\",\n          \"doc\": \"Direction of light source when map is rotated.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"hillshade-illumination-direction\": {\n          \"type\": {\n            \"NumberArray\": {\n              \"min\": 0.0,\n              \"max\": 359.0\n            }\n          },\n          \"default\": 335,\n          \"doc\": \"The direction of the light source(s) used to generate the hillshading with 0 as the top of the viewport if `hillshade-illumination-anchor` is set to `viewport` and due north if `hillshade-illumination-anchor` is set to `map`. Only when `hillshade-method` is set to `multidirectional` can you specify multiple light sources.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"hillshade-method\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"basic\",\n                \"combined\",\n                \"igor\",\n                \"multidirectional\",\n                \"standard\"\n              ]\n            }\n          },\n          \"default\": \"standard\",\n          \"doc\": \"The hillshade algorithm to use, one of `standard`, `basic`, `combined`, `igor`, or `multidirectional`. ![image](assets/hillshade_methods.png)\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"hillshade-shadow-color\": {\n          \"type\": \"ColorArray\",\n          \"default\": \"#000000\",\n          \"doc\": \"The shading color of areas that face away from the light source(s). Only when `hillshade-method` is set to `multidirectional` can you specify multiple light sources.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      }\n    },\n    \"line\": {\n      \"layout\": {\n        \"line-cap\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"butt\",\n                \"round\",\n                \"square\"\n              ]\n            }\n          },\n          \"default\": \"butt\",\n          \"doc\": \"The display of line endings.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"line-join\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"bevel\",\n                \"miter\",\n                \"round\"\n              ]\n            }\n          },\n          \"default\": \"miter\",\n          \"doc\": \"The display of lines when joining.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"line-miter-limit\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 2,\n          \"doc\": \"Used to automatically convert miter joins to bevel joins for sharp angles.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"line-round-limit\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 1.05,\n          \"doc\": \"Used to automatically convert round joins to miter joins for shallow angles.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"line-sort-key\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Sorts features in ascending order based on this value. Features with a higher sort key will appear above features with a lower sort key.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"line-blur\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Blur applied to the line, in pixels.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"line-color\": {\n          \"type\": \"Color\",\n          \"default\": \"#000000\",\n          \"doc\": \"The color with which the line will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"line-dasharray\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": null\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Specifies the lengths of the alternating dashes and gaps that form the dash pattern. The lengths are later scaled by the line width. To convert a dash length to pixels, multiply the length by the current line width. GeoJSON sources with `lineMetrics: true` specified won't render dashed lines to the expected scale. Zoom-dependent expressions will be evaluated only at integer zoom levels. The only way to create an array value is using `[\\\"literal\\\", [...]]`; arrays cannot be read from or derived from feature properties.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"line-gap-width\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Draws a line casing outside of a line's actual path. Value indicates the width of the inner gap.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"line-gradient\": {\n          \"type\": \"Color\",\n          \"default\": null,\n          \"doc\": \"Defines a gradient with which to color a line feature. Can only be used with GeoJSON sources that specify `\\\"lineMetrics\\\": true`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"line-offset\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"The line's offset. For linear features, a positive value offsets the line to the right, relative to the direction of the line, and a negative value to the left. For polygon features, a positive value results in an inset, and a negative value results in an outset.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"line-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity at which the line will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"line-pattern\": {\n          \"type\": {\n            \"ResolvedImage\": {\n              \"tokens\": false\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Name of image in sprite to use for drawing image lines. For seamless patterns, image width must be a factor of two (2, 4, 8, ..., 512). Note that zoom-dependent expressions will be evaluated only at integer zoom levels.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"line-translate\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": 2\n            }\n          },\n          \"default\": [\n            0,\n            0\n          ],\n          \"doc\": \"The geometry's offset. Values are [x, y] where negatives indicate left and up, respectively.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"line-translate-anchor\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"map\",\n          \"doc\": \"Controls the frame of reference for `line-translate`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"line-width\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"Stroke thickness.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        }\n      }\n    },\n    \"raster\": {\n      \"layout\": {\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"raster-brightness-max\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"Increase or reduce the brightness of the image. The value is the maximum brightness.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"raster-brightness-min\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Increase or reduce the brightness of the image. The value is the minimum brightness.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"raster-contrast\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": -1.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Increase or reduce the contrast of the image.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"raster-fade-duration\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 300,\n          \"doc\": \"Fade duration when a new tile is added, or when a video is started or its coordinates are updated.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"raster-hue-rotate\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Rotates hues around the color wheel.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"raster-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity at which the image will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"raster-resampling\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"linear\",\n                \"nearest\"\n              ]\n            }\n          },\n          \"default\": \"linear\",\n          \"doc\": \"The resampling/interpolation method to use for overscaling, also known as texture magnification filter\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"raster-saturation\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": -1.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Increase or reduce the saturation of the image.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      }\n    },\n    \"symbol\": {\n      \"layout\": {\n        \"icon-allow-overlap\": {\n          \"type\": \"Boolean\",\n          \"default\": false,\n          \"doc\": \"If true, the icon will be visible even if it collides with other previously drawn symbols.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"icon-anchor\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"bottom\",\n                \"bottom-left\",\n                \"bottom-right\",\n                \"center\",\n                \"left\",\n                \"right\",\n                \"top\",\n                \"top-left\",\n                \"top-right\"\n              ]\n            }\n          },\n          \"default\": \"center\",\n          \"doc\": \"Part of the icon placed closest to the anchor.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"icon-ignore-placement\": {\n          \"type\": \"Boolean\",\n          \"default\": false,\n          \"doc\": \"If true, other symbols can be visible even if they collide with the icon.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"icon-image\": {\n          \"type\": {\n            \"ResolvedImage\": {\n              \"tokens\": true\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Name of image in sprite to use for drawing an image background.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"icon-keep-upright\": {\n          \"type\": \"Boolean\",\n          \"default\": false,\n          \"doc\": \"If true, the icon may be flipped to prevent it from being rendered upside-down.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"icon-offset\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": 2\n            }\n          },\n          \"default\": [\n            0,\n            0\n          ],\n          \"doc\": \"Offset distance of icon from its anchor. Positive values indicate right and down, while negative values indicate left and up. Each component is multiplied by the value of `icon-size` to obtain the final offset in pixels. When combined with `icon-rotate` the offset will be as if the rotated direction was up.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"icon-optional\": {\n          \"type\": \"Boolean\",\n          \"default\": false,\n          \"doc\": \"If true, text will display without their corresponding icons when the icon collides with other symbols and the text does not.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"icon-overlap\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"always\",\n                \"cooperative\",\n                \"never\"\n              ]\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Allows for control over whether to show an icon when it overlaps other symbols on the map. If `icon-overlap` is not set, `icon-allow-overlap` is used instead.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"icon-padding\": {\n          \"type\": \"Padding\",\n          \"default\": [\n            2\n          ],\n          \"doc\": \"Size of additional area round the icon bounding box used for detecting symbol collisions.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"icon-pitch-alignment\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"auto\",\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"auto\",\n          \"doc\": \"Orientation of icon when map is pitched.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"icon-rotate\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Rotates the icon clockwise.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"icon-rotation-alignment\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"auto\",\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"auto\",\n          \"doc\": \"In combination with `symbol-placement`, determines the rotation behavior of icons.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"icon-size\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"Scales the original size of the icon by the provided factor. The new pixel size of the image will be the original pixel size multiplied by `icon-size`. 1 is the original size; 3 triples the size of the image.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"icon-text-fit\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"both\",\n                \"height\",\n                \"none\",\n                \"width\"\n              ]\n            }\n          },\n          \"default\": \"none\",\n          \"doc\": \"Scales the icon to fit around the associated text.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"icon-text-fit-padding\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": 4\n            }\n          },\n          \"default\": [\n            0,\n            0,\n            0,\n            0\n          ],\n          \"doc\": \"Size of the additional area added to dimensions determined by `icon-text-fit`, in clockwise order: top, right, bottom, left.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"symbol-avoid-edges\": {\n          \"type\": \"Boolean\",\n          \"default\": false,\n          \"doc\": \"If true, the symbols will not cross tile edges to avoid mutual collisions. Recommended in layers that don't have enough padding in the vector tile to prevent collisions, or if it is a point symbol layer placed after a line symbol layer. When using a client that supports global collision detection, like MapLibre GL JS version 0.42.0 or greater, enabling this property is not needed to prevent clipped labels at tile boundaries.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"symbol-placement\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"line\",\n                \"line-center\",\n                \"point\"\n              ]\n            }\n          },\n          \"default\": \"point\",\n          \"doc\": \"Label placement relative to its geometry.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"symbol-sort-key\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Sorts features in ascending order based on this value. Features with lower sort keys are drawn and placed first.  When `icon-allow-overlap` or `text-allow-overlap` is `false`, features with a lower sort key will have priority during placement. When `icon-allow-overlap` or `text-allow-overlap` is set to `true`, features with a higher sort key will overlap over features with a lower sort key.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"symbol-spacing\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 1.0,\n              \"max\": null\n            }\n          },\n          \"default\": 250,\n          \"doc\": \"Distance between two symbol anchors.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"symbol-z-order\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"auto\",\n                \"source\",\n                \"viewport-y\"\n              ]\n            }\n          },\n          \"default\": \"auto\",\n          \"doc\": \"Determines whether overlapping symbols in the same layer are rendered in the order that they appear in the data source or by their y-position relative to the viewport. To control the order and prioritization of symbols otherwise, use `symbol-sort-key`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-allow-overlap\": {\n          \"type\": \"Boolean\",\n          \"default\": false,\n          \"doc\": \"If true, the text will be visible even if it collides with other previously drawn symbols.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-anchor\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"bottom\",\n                \"bottom-left\",\n                \"bottom-right\",\n                \"center\",\n                \"left\",\n                \"right\",\n                \"top\",\n                \"top-left\",\n                \"top-right\"\n              ]\n            }\n          },\n          \"default\": \"center\",\n          \"doc\": \"Part of the text placed closest to the anchor.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-field\": {\n          \"type\": {\n            \"Formatted\": {\n              \"tokens\": true\n            }\n          },\n          \"default\": \"\",\n          \"doc\": \"Value to use for a text label. If a plain `string` is provided, it will be treated as a `formatted` with default/inherited formatting options.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-font\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"String\",\n              \"length\": null\n            }\n          },\n          \"default\": [\n            \"Open Sans Regular\",\n            \"Arial Unicode MS Regular\"\n          ],\n          \"doc\": \"Fonts to use for displaying text. If the `glyphs` root property is specified, this array is joined together and interpreted as a font stack name. Otherwise, it is interpreted as a cascading fallback list of local font names.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-ignore-placement\": {\n          \"type\": \"Boolean\",\n          \"default\": false,\n          \"doc\": \"If true, other symbols can be visible even if they collide with the text.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-justify\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"auto\",\n                \"center\",\n                \"left\",\n                \"right\"\n              ]\n            }\n          },\n          \"default\": \"center\",\n          \"doc\": \"Text justification options.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-keep-upright\": {\n          \"type\": \"Boolean\",\n          \"default\": true,\n          \"doc\": \"If true, the text may be flipped vertically to prevent it from being rendered upside-down.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-letter-spacing\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Text tracking amount.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-line-height\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 1.2,\n          \"doc\": \"Text leading value for multi-line text.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-max-angle\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 45,\n          \"doc\": \"Maximum angle change between adjacent characters.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-max-width\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 10,\n          \"doc\": \"The maximum line width for text wrapping.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-offset\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": 2\n            }\n          },\n          \"default\": [\n            0,\n            0\n          ],\n          \"doc\": \"Offset distance of text from its anchor. Positive values indicate right and down, while negative values indicate left and up. If used with text-variable-anchor, input values will be taken as absolute values. Offsets along the x- and y-axis will be applied automatically based on the anchor position.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-optional\": {\n          \"type\": \"Boolean\",\n          \"default\": false,\n          \"doc\": \"If true, icons will display without their corresponding text when the text collides with other symbols and the icon does not.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-overlap\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"always\",\n                \"cooperative\",\n                \"never\"\n              ]\n            }\n          },\n          \"default\": null,\n          \"doc\": \"Allows for control over whether to show symbol text when it overlaps other symbols on the map. If `text-overlap` is not set, `text-allow-overlap` is used instead\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-padding\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 2,\n          \"doc\": \"Size of the additional area around the text bounding box used for detecting symbol collisions.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-pitch-alignment\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"auto\",\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"auto\",\n          \"doc\": \"Orientation of text when map is pitched.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-radial-offset\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Radial offset of text, in the direction of the symbol's anchor. Useful in combination with `text-variable-anchor`, which defaults to using the two-dimensional `text-offset` if present.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-rotate\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": null,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Rotates the text clockwise.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-rotation-alignment\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"auto\",\n                \"map\",\n                \"viewport\",\n                \"viewport-glyph\"\n              ]\n            }\n          },\n          \"default\": \"auto\",\n          \"doc\": \"In combination with `symbol-placement`, determines the rotation behavior of the individual glyphs forming the text.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-size\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 16,\n          \"doc\": \"Font size.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-transform\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"lowercase\",\n                \"none\",\n                \"uppercase\"\n              ]\n            }\n          },\n          \"default\": \"none\",\n          \"doc\": \"Specifies how to capitalize text, similar to the CSS `text-transform` property.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-variable-anchor\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": {\n                \"Enum\": [\n                  \"bottom\",\n                  \"bottom-left\",\n                  \"bottom-right\",\n                  \"center\",\n                  \"left\",\n                  \"right\",\n                  \"top\",\n                  \"top-left\",\n                  \"top-right\"\n                ]\n              },\n              \"length\": null\n            }\n          },\n          \"default\": null,\n          \"doc\": \"To increase the chance of placing high-priority labels on the map, you can provide an array of `text-anchor` locations: the renderer will attempt to place the label at each location, in order, before moving onto the next label. Use `text-justify: auto` to choose justification based on anchor position. To apply an offset, use the `text-radial-offset` or the two-dimensional `text-offset`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-variable-anchor-offset\": {\n          \"type\": \"VariableAnchorOffsetCollection\",\n          \"default\": null,\n          \"doc\": \"To increase the chance of placing high-priority labels on the map, you can provide an array of `text-anchor` locations, each paired with an offset value. The renderer will attempt to place the label at each location, in order, before moving on to the next location+offset. Use `text-justify: auto` to choose justification based on anchor position. \\n\\n The length of the array must be even, and must alternate between enum and point entries. i.e., each anchor location must be accompanied by a point, and that point defines the offset when the corresponding anchor location is used. Positive offset values indicate right and down, while negative values indicate left and up. Anchor locations may repeat, allowing the renderer to try multiple offsets to try and place a label using the same anchor. \\n\\n When present, this property takes precedence over `text-anchor`, `text-variable-anchor`, `text-offset`, and `text-radial-offset`. \\n\\n ```json \\n\\n { \\\"text-variable-anchor-offset\\\": [\\\"top\\\", [0, 4], \\\"left\\\", [3,0], \\\"bottom\\\", [1, 1]] } \\n\\n ``` \\n\\n When the renderer chooses the `top` anchor, `[0, 4]` will be used for `text-offset`; the text will be shifted down by 4 ems. \\n\\n When the renderer chooses the `left` anchor, `[3, 0]` will be used for `text-offset`; the text will be shifted right by 3 ems.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": false\n          }\n        },\n        \"text-writing-mode\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": {\n                \"Enum\": [\n                  \"horizontal\",\n                  \"vertical\"\n                ]\n              },\n              \"length\": null\n            }\n          },\n          \"default\": null,\n          \"doc\": \"The property allows control over a symbol's orientation. Note that the property values act as a hint, so that a symbol whose language doesn’t support the provided orientation will be laid out in its natural orientation. Example: English point symbol will be rendered horizontally even if array value contains single 'vertical' enum value. The order of elements in an array define priority order for the placement of an orientation variant.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"visibility\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"none\",\n                \"visible\"\n              ]\n            }\n          },\n          \"default\": \"visible\",\n          \"doc\": \"Whether this layer is displayed.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": false,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      },\n      \"paint\": {\n        \"icon-color\": {\n          \"type\": \"Color\",\n          \"default\": \"#000000\",\n          \"doc\": \"The color of the icon. This can only be used with SDF icons.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"icon-halo-blur\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Fade out the halo towards the outside.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"icon-halo-color\": {\n          \"type\": \"Color\",\n          \"default\": \"rgba(0, 0, 0, 0)\",\n          \"doc\": \"The color of the icon's halo. Icon halos can only be used with SDF icons.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"icon-halo-width\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Distance of halo to the icon outline. \\n\\nThe unit is in pixels only for SDF sprites that were created with a blur radius of 8, multiplied by the display density. I.e., the radius needs to be 16 for `@2x` sprites, etc.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"icon-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity at which the icon will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"icon-translate\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": 2\n            }\n          },\n          \"default\": [\n            0,\n            0\n          ],\n          \"doc\": \"Distance that the icon's anchor is moved from its original placement. Positive values indicate right and down, while negative values indicate left and up.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"icon-translate-anchor\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"map\",\n          \"doc\": \"Controls the frame of reference for `icon-translate`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-color\": {\n          \"type\": \"Color\",\n          \"default\": \"#000000\",\n          \"doc\": \"The color with which the text will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"text-halo-blur\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"The halo's fadeout distance towards the outside.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"text-halo-color\": {\n          \"type\": \"Color\",\n          \"default\": \"rgba(0, 0, 0, 0)\",\n          \"doc\": \"The color of the text's halo, which helps it stand out from backgrounds.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"text-halo-width\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": null\n            }\n          },\n          \"default\": 0,\n          \"doc\": \"Distance of halo to the font outline. Max text halo width is 1/4 of the font-size.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"text-opacity\": {\n          \"type\": {\n            \"Number\": {\n              \"min\": 0.0,\n              \"max\": 1.0\n            }\n          },\n          \"default\": 1,\n          \"doc\": \"The opacity at which the text will be drawn.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": true,\n            \"global_state\": true\n          }\n        },\n        \"text-translate\": {\n          \"type\": {\n            \"Array\": {\n              \"element\": \"Number\",\n              \"length\": 2\n            }\n          },\n          \"default\": [\n            0,\n            0\n          ],\n          \"doc\": \"Distance that the text's anchor is moved from its original placement. Positive values indicate right and down, while negative values indicate left and up.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": true,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        },\n        \"text-translate-anchor\": {\n          \"type\": {\n            \"Enum\": {\n              \"values\": [\n                \"map\",\n                \"viewport\"\n              ]\n            }\n          },\n          \"default\": \"map\",\n          \"doc\": \"Controls the frame of reference for `text-translate`.\",\n          \"required\": false,\n          \"expression\": {\n            \"interpolated\": false,\n            \"zoom\": true,\n            \"feature\": false,\n            \"global_state\": false\n          }\n        }\n      }\n    }\n  }\n}"},"old":{"module_name":"maplibre_style_spec__mir__preprocessing__layers","metadata":{},"snapshot":""}}
